{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "MultilineInput(*)"
    ],
    "deny": []
  },
  "thinking": {
    "type": "enabled",
    "budgetTokens": 10000
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // \"\"'); echo \"$cmd\" | grep -q 'nh os switch' && { kill $(pgrep -f quickshell) 2>/dev/null; sleep 1; noctalia-shell & } || true"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "obsidian": {
      "command": "mcp-server-filesystem",
      "args": ["/home/phatle/Documents/Obsidian"],
      "env": {}
    }
  },
  "advisorModel": "opus",
  "theme": "dark",
  "editorMode": "vim",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  }
}
